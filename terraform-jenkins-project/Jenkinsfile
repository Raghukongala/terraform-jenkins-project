pipeline {
    agent any

    parameters {
        choice(name: 'ENV',         choices: ['dev', 'staging', 'prod'], description: 'Target environment')
        choice(name: 'ACTION',      choices: ['plan', 'apply', 'destroy', 'deploy'], description: 'Terraform action or deploy app')
        booleanParam(name: 'AUTO_APPROVE', defaultValue: false, description: 'Skip manual approval (non-prod only)')
    }

    environment {
        TF_VERSION       = '1.7.5'
        TF_DIR           = "terraform-jenkins-project/envs/${params.ENV}"
        TF_IN_AUTOMATION = 'true'
        TF_CLI_ARGS      = '-no-color'
        AWS_REGION       = 'ap-south-1'
        AWS_ACCOUNT_ID   = '957948932374'
        ECR_REPO         = "myapp-${params.ENV}-app"
        IMAGE_TAG        = "${BUILD_NUMBER}"
    }

    options {
        timestamps()
        timeout(time: 60, unit: 'MINUTES')
        disableConcurrentBuilds()
    }

    stages {

        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Terraform Init') {
            when { expression { params.ACTION != 'deploy' } }
            steps {
                withCredentials([
                    string(credentialsId: 'Accesskey',         variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'Secret access key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir("${TF_DIR}") {
                        sh 'terraform init -reconfigure'
                    }
                }
            }
        }

        stage('Validate & Lint') {
            when { expression { params.ACTION != 'deploy' } }
            parallel {
                stage('Validate') {
                    steps {
                        withCredentials([
                            string(credentialsId: 'Accesskey',         variable: 'AWS_ACCESS_KEY_ID'),
                            string(credentialsId: 'Secret access key', variable: 'AWS_SECRET_ACCESS_KEY')
                        ]) {
                            dir("${TF_DIR}") {
                                sh 'terraform validate'
                            }
                        }
                    }
                }
                stage('TFLint') {
                    steps {
                        dir("${TF_DIR}") {
                            sh 'tflint --init && tflint || true'
                        }
                    }
                }
                stage('Checkov Security Scan') {
                    steps {
                        dir("${TF_DIR}") {
                            sh 'checkov -d . --framework terraform --output junitxml > checkov-report.xml || true'
                        }
                    }
                }
            }
        }

        stage('Terraform Plan') {
            when { expression { params.ACTION in ['plan', 'apply'] } }
            steps {
                withCredentials([
                    string(credentialsId: 'Accesskey',         variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'Secret access key', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'db-password',       variable: 'TF_VAR_db_password')
                ]) {
                    dir("${TF_DIR}") {
                        sh """
                            export AWS_DEFAULT_REGION=ap-south-1
                            terraform plan \\
                              -var-file="terraform.tfvars" \\
                              -out=tfplan \\
                              -detailed-exitcode || [ \$? -eq 2 ]
                        """
                        sh 'terraform show -no-color tfplan > tfplan.txt'
                        archiveArtifacts artifacts: 'tfplan.txt', fingerprint: true
                    }
                }
            }
        }

        stage('Approval') {
            when {
                allOf {
                    expression { params.ACTION in ['apply', 'destroy'] }
                    anyOf {
                        expression { params.ENV == 'prod' }
                        expression { !params.AUTO_APPROVE }
                    }
                }
            }
            steps {
                script {
                    input message: "Approve Terraform ${params.ACTION.toUpperCase()} on ${params.ENV}?", ok: 'Approve'
                }
            }
        }

        stage('Terraform Apply') {
            when { expression { params.ACTION == 'apply' } }
            steps {
                withCredentials([
                    string(credentialsId: 'Accesskey',         variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'Secret access key', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'db-password',       variable: 'TF_VAR_db_password')
                ]) {
                    dir("${TF_DIR}") {
                        sh '''
                            export AWS_DEFAULT_REGION=ap-south-1
                            terraform apply -auto-approve tfplan
                        '''
                    }
                }
            }
        }

        stage('Terraform Destroy') {
            when { expression { params.ACTION == 'destroy' } }
            steps {
                withCredentials([
                    string(credentialsId: 'Accesskey',         variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'Secret access key', variable: 'AWS_SECRET_ACCESS_KEY'),
                    string(credentialsId: 'db-password',       variable: 'TF_VAR_db_password')
                ]) {
                    dir("${TF_DIR}") {
                        sh """
                            export AWS_DEFAULT_REGION=ap-south-1
                            terraform destroy -auto-approve -var-file=\"terraform.tfvars\"
                        """
                    }
                }
            }
        }

        stage('Docker Build') {
            when { expression { params.ACTION == 'deploy' } }
            steps {
                dir('terraform-jenkins-project/app') {
                    sh "docker build -t ${ECR_REPO}:${IMAGE_TAG} ."
                }
            }
        }

        stage('Push to ECR') {
            when { expression { params.ACTION == 'deploy' } }
            steps {
                withCredentials([
                    string(credentialsId: 'Accesskey',         variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'Secret access key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh """
                        export AWS_DEFAULT_REGION=${AWS_REGION}
                        aws ecr get-login-password --region ${AWS_REGION} | docker login --username AWS --password-stdin ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com
                        docker tag ${ECR_REPO}:${IMAGE_TAG} ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO}:${IMAGE_TAG}
                        docker tag ${ECR_REPO}:${IMAGE_TAG} ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO}:latest
                        docker push ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO}:${IMAGE_TAG}
                        docker push ${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO}:latest
                    """
                }
            }
        }

        stage('Deploy to ECS') {
            when { expression { params.ACTION == 'deploy' } }
            steps {
                withCredentials([
                    string(credentialsId: 'Accesskey',         variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'Secret access key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    sh """
                        export AWS_DEFAULT_REGION=${AWS_REGION}
                        aws ecs update-service \
                          --cluster myapp-${params.ENV}-cluster \
                          --service myapp-${params.ENV}-service \
                          --force-new-deployment \
                          --region ${AWS_REGION}
                        aws ecs wait services-stable \
                          --cluster myapp-${params.ENV}-cluster \
                          --services myapp-${params.ENV}-service \
                          --region ${AWS_REGION}
                    """
                }
            }
        }

        stage('Output') {
            when { expression { params.ACTION == 'apply' } }
            steps {
                withCredentials([
                    string(credentialsId: 'Accesskey',         variable: 'AWS_ACCESS_KEY_ID'),
                    string(credentialsId: 'Secret access key', variable: 'AWS_SECRET_ACCESS_KEY')
                ]) {
                    dir("${TF_DIR}") {
                        sh '''
                            export AWS_DEFAULT_REGION=ap-south-1
                            terraform output -json > tf-outputs.json
                        '''
                        archiveArtifacts artifacts: 'tf-outputs.json', fingerprint: true
                    }
                }
            }
        }
    }

    post {
        always {
            cleanWs()
        }
        success {
            echo "Pipeline completed successfully for ${params.ENV} - ${params.ACTION}"
        }
        failure {
            echo "Pipeline FAILED for ${params.ENV} - ${params.ACTION}"
        }
    }
}
